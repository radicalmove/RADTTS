[Unit]
Description=RADTTS dev service
After=network.target

[Service]
Type=simple
User=fldadmin
Group=fldadmin
WorkingDirectory=/home/fldadmin/radtts-dev
EnvironmentFile=/home/fldadmin/radtts-dev/.env
ExecStart=/home/fldadmin/radtts-dev/.venv/bin/gunicorn -k uvicorn.workers.UvicornWorker -w 1 -b 127.0.0.1:8011 radtts.api:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
